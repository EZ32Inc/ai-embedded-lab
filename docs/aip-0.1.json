    {
      "op": "scope.start",
      "category": "scope",
      "auth": "claim",
      "optional": true,
      "args": {
        "channels": "string[]",
        "sample_hz": "int",
        "duration_ms": "int",
        "trigger": "object?",
        "encoding": "string?"
      },
      "result": {
        "capture_id": "string"
      }
    },
    {
      "op": "scope.read",
      "category": "scope",
      "auth": "claim",
      "optional": true,
