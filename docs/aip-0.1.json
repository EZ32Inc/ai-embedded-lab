      },
      "result": {
        "handle": "string"
      }
    },
    {
      "op": "uart.read",
      "category": "uart",
      "auth": "claim",
      "optional": true,
      "args": {
        "handle": "string",
        "max_bytes": "int",
        "timeout_ms": "int?"
      },
      "result": {
        "data_b64": "string",
        "n": "int"
      }
    },
    {
      "op": "uart.write",
      "category": "uart",
      "auth": "claim",
      "optional": true,
      "args": {
        "handle": "string",
        "data_b64": "string"
      },
      "result": {
        "n": "int"
      }
