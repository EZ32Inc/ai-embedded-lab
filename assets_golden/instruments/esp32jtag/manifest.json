{
  "schema": "ael.instrument.manifest.v0.1",
  "id": "esp32jtag",
  "kind": "instrument",
  "transports": [
    { "type": "tcp", "endpoint_hint": "192.168.4.1:4242" },
    { "type": "http", "endpoint_hint": "https://192.168.4.1:443" }
  ],
  "communication": {
    "primary": "gdb_remote",
    "surfaces": [
      {
        "name": "gdb_remote",
        "transport": "wifi",
        "endpoint": "192.168.4.1:4242",
        "protocol": "gdb_remote",
        "invocation_style": "request_response"
      },
      {
        "name": "web_api",
        "transport": "wifi",
        "endpoint": "https://192.168.4.1:443",
        "protocol": "esp32jtag_web_api_v1",
        "invocation_style": "request_response"
      }
    ]
  },
  "capabilities": [
    { "name": "debug.swd" },
    { "name": "observe.logic", "channels": 8 },
    { "name": "observe.uart" }
  ],
  "identity": {
    "network": { "ip": "192.168.4.1" }
  },
  "docs": {
    "ai": [{ "path": "docs_ai.md" }]
  }
}
