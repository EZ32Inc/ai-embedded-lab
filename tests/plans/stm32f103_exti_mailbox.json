{
  "schema_version": "1.0",
  "test_kind": "baremetal_mailbox",
  "name": "stm32f103_exti_mailbox",
  "board": "stm32f103_gpio",
  "supported_instruments": ["stlink", "esp32jtag"],
  "requires": {
    "mailbox": true,
    "datacapture": false
  },
  "labels": ["mailbox", "portable", "cross_instrument"],
  "covers": ["exti"],
  "preflight": { "enabled": false },
  "build": {
    "project_dir": "firmware/targets/stm32f103_exti_mailbox",
    "artifact_stem": "stm32f103_exti_mailbox_app",
    "build_dir": "artifacts/build_stm32f103_exti_mailbox"
  },
  "signal_checks": [],
  "mailbox_verify": {
    "addr": "0x20004C00",
    "settle_s": 1.0
  },
  "bench_setup": {
    "notes": "EXTI mailbox test. Requires PA8 -> PB8. DUT generates edges, validates EXTI activity internally, and reports PASS/FAIL through the AEL mailbox.",
    "peripheral_signals": [
      {
        "role": "EXTI_SOURCE",
        "dut_signal": "PA8",
        "direction": "output"
      },
      {
        "role": "EXTI_SELF_CHECK_INPUT",
        "dut_signal": "PB8",
        "direction": "input"
      }
    ]
  }
}
