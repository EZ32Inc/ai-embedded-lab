{
  "name": "stm32f411_spi_banner",
  "board": "stm32f411ceu6",
  "pin": "sig",
  "duration_s": 1.0,
  "min_freq_hz": 15.0,
  "max_freq_hz": 35.0,
  "duty_min": 0.4,
  "duty_max": 0.6,
  "min_edges": 2,
  "max_edges": 20000,
  "build": {
    "project_dir": "firmware/targets/stm32f411_spi",
    "artifact_stem": "stm32f411_spi_app",
    "build_dir": "artifacts/build_stm32f411_spi_banner"
  },
  "bench_setup": {
    "peripheral_signals": [
      {
        "role": "SPI2_SCK",
        "dut_signal": "PB13",
        "direction": "output",
        "notes": "Firmware drives SPI2 clock on PB13 and the bench also observes it on P0.2."
      },
      {
        "role": "SPI2_MISO",
        "dut_signal": "PB14",
        "direction": "input"
      },
      {
        "role": "SPI2_MOSI",
        "dut_signal": "PB15",
        "direction": "output"
      }
    ],
    "external_inputs": [
      {
        "source": "SPI_LOOPBACK",
        "dut_signal": "PB14/SPI2_MISO",
        "kind": "digital_loopback",
        "required": true,
        "status": "provisioned",
        "notes": "Execution contract: physically connect PB15/SPI2_MOSI to PB14/SPI2_MISO. Firmware performs a bounded SPI loopback self-check internally and exports SPI-valid status on PA2."
      }
    ]
  }
}
