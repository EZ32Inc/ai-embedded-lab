{
  "schema_version": "1.0",
  "name": "esp32c5_gpio_adc_loopback",
  "test_kind": "instrument_specific",
  "board": "esp32c5_devkit_dual_usb",
  "supported_instruments": ["esp32_meter"],
  "requires": {"mailbox": false, "datacapture": false},
  "labels": ["gpio", "adc", "loopback"],
  "covers": ["gpio", "adc"],
  "notes": "Wire B: GPIO6 (output, safe_output) → GPIO1 (ADC1_CH0 input). Drives high/low, reads ADC, checks thresholds. Proves GPIO output and ADC input path.",
  "wiring": {
    "required": [
      {"from": "GPIO6", "to": "GPIO1", "label": "Wire B — GPIO output → ADC1_CH0 input"}
    ]
  },
  "build": {
    "project_dir": "firmware/targets/esp32c5_gpio_adc_loopback",
    "artifact_stem": "ael_esp32c5_gpio_adc_loopback",
    "build_dir": "artifacts/build_esp32c5_gpio_adc_loopback"
  },
  "preflight": {
    "enabled": false
  },
  "observe_uart": {
    "enabled": true,
    "instrument_spec": "esp32c5_uart_bridge",
    "port": "/dev/ttyACM0",
    "baud": 115200,
    "profile": "espidf",
    "duration_s": 10,
    "expect_patterns": [
      "AEL_GPIOADC",
      "PASS"
    ]
  }
}
