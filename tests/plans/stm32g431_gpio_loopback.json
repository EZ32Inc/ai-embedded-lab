{
  "name": "stm32g431_gpio_loopback",
  "board": "stm32g431cbu6",
  "pin": "sig",
  "duration_s": 1.0,
  "min_freq_hz": 30.0,
  "max_freq_hz": 70.0,
  "duty_min": 0.3,
  "duty_max": 0.7,
  "min_edges": 5,
  "max_edges": 20000,
  "build": {
    "project_dir": "firmware/targets/stm32g431_gpio_loopback",
    "artifact_stem": "stm32g431_gpio_loopback_app",
    "build_dir": "artifacts/build_stm32g431_gpio_loopback"
  },
  "bench_setup": {
    "peripheral_signals": [
      { "role": "GPIO_OUT", "dut_signal": "PA8", "direction": "output",
        "notes": "GPIO output toggles 100Hz. PA8→PA6 loopback wire." },
      { "role": "GPIO_IN",  "dut_signal": "PA6", "direction": "input",
        "notes": "GPIO input read via IDR. PA2 toggles ~50Hz when both levels sensed in 100ms window." }
    ]
  }
}
