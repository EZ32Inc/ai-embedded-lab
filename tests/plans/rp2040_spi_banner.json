{
  "name": "rp2040_spi_banner",
  "board": "rp2040_pico",
  "pin": "sig",
  "sample_rate_hz": 260000,
  "duration_s": 1.0,
  "min_edges": 2,
  "max_edges": 20000,
  "build": {
    "project_dir": "firmware/targets/rp2040_pico_spi",
    "artifact_stem": "pico_spi_banner",
    "build_dir": "artifacts/build_rp2040_spi_banner"
  },
  "observe_uart": {
    "enabled": true,
    "port": "/dev/ttyACM0",
    "baud": 115200,
    "profile": "rp2040",
    "duration_s": 6,
    "expect_patterns": [
      "AEL_READY RP2040 SPI"
    ]
  },
  "bench_setup": {
    "serial_console": {
      "port": "/dev/ttyACM0",
      "baud": 115200,
      "required": true
    },
    "peripheral_signals": [
      {
        "role": "SPI0_SCK",
        "dut_signal": "GPIO2",
        "direction": "output"
      },
      {
        "role": "SPI0_MOSI",
        "dut_signal": "GPIO3",
        "direction": "output"
      },
      {
        "role": "SPI0_MISO",
        "dut_signal": "GPIO4",
        "direction": "input"
      }
    ]
  }
}
