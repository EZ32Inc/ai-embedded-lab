{
  "schema_version": "1.0",
  "name": "esp32s3_devkit_test_adc",
  "test_kind": "instrument_specific",
  "board": "esp32s3_devkit_dual_usb",
  "supported_instruments": [],
  "requires": {
    "mailbox": false,
    "datacapture": false
  },
  "labels": [
    "stage2",
    "selftest",
    "truth_layer"
  ],
  "covers": [
    "adc"
  ],
  "notes": "Stage 2: ADC1 loopback. GPIO2 drives -> GPIO1 (ADC1_CH0). No LP-IO limitation on S3.",
  "wiring": {
    "required": [
      {
        "from": "GPIO2",
        "to": "GPIO1",
        "label": "ADC drive -> ADC1_CH0 input"
      }
    ]
  },
  "build": {
    "project_dir": "firmware/targets/esp32s3_devkit/test_adc",
    "artifact_stem": "ael_esp32s3_devkit_test_adc",
    "build_dir": "artifacts/build_esp32s3_devkit_test_adc"
  },
  "preflight": {
    "enabled": false
  },
  "observe_uart": {
    "enabled": true,
    "port": "/dev/ttyACM0",
    "baud": 115200,
    "profile": "espidf",
    "duration_s": 8,
    "reset_strategy": "rts",
    "boot_signatures": ["rst:0x"],
    "expect_patterns": [
      "AEL_ADC.*PASS"
    ]
  }
}
