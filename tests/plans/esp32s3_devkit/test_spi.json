{
  "schema_version": "1.0",
  "name": "esp32s3_devkit_test_spi",
  "test_kind": "instrument_specific",
  "board": "esp32s3_devkit_dual_usb",
  "supported_instruments": [],
  "requires": {
    "mailbox": false,
    "datacapture": false
  },
  "labels": [
    "stage2",
    "selftest",
    "truth_layer"
  ],
  "covers": [
    "spi"
  ],
  "notes": "Stage 2: SPI2 MOSI<->MISO loopback. Jumper GPIO11 <-> GPIO13. CLK=GPIO12, CS=GPIO10.",
  "wiring": {
    "required": [
      {
        "from": "GPIO11",
        "to": "GPIO13",
        "label": "SPI2 MOSI <-> MISO loopback"
      }
    ]
  },
  "build": {
    "project_dir": "firmware/targets/esp32s3_devkit/test_spi",
    "artifact_stem": "ael_esp32s3_devkit_test_spi",
    "build_dir": "artifacts/build_esp32s3_devkit_test_spi"
  },
  "preflight": {
    "enabled": false
  },
  "observe_uart": {
    "enabled": true,
    "port": "/dev/ttyACM2",
    "baud": 115200,
    "profile": "espidf",
    "duration_s": 8,
    "reset_strategy": "rts",
    "boot_signatures": ["rst:0x"],
    "expect_patterns": [
      "AEL_SPI.*PASS"
    ]
  }
}
