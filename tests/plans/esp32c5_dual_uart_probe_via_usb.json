{
  "schema_version": "1.0",
  "name": "esp32c5_dual_uart_probe_via_usb",
  "test_kind": "instrument_specific",
  "board": "esp32c5_devkit_dual_usb",
  "supported_instruments": ["esp32_meter"],
  "requires": {"mailbox": false, "datacapture": false},
  "labels": ["uart", "selftest_only"],
  "covers": ["uart"],
  "notes": "Validates native USB Serial/JTAG path (Espressif CDC, /dev/ttyACM3). Both ports receive printf simultaneously via secondary console config.",
  "build": {
    "project_dir": "firmware/targets/esp32c5_dual_uart_probe",
    "artifact_stem": "ael_esp32c5_dual_uart_probe",
    "build_dir": "artifacts/build_esp32c5_dual_uart_probe"
  },
  "preflight": {
    "enabled": false
  },
  "observe_uart": {
    "enabled": true,
    "instrument_spec": "esp32c5_usb_jtag",
    "port": "/dev/ttyACM3",
    "baud": 115200,
    "profile": "espidf",
    "duration_s": 10,
    "expect_patterns": [
      "AEL_READY ESP32C5 DUAL"
    ]
  }
}
