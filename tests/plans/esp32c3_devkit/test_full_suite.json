{
  "schema_version": "1.0",
  "name": "esp32c3_devkit_test_full_suite",
  "test_kind": "instrument_specific",
  "board": "esp32c3_devkit_native_usb",
  "supported_instruments": [],
  "requires": {
    "mailbox": false,
    "datacapture": false
  },
  "labels": [
    "full_suite",
    "convenience_layer"
  ],
  "covers": [
    "nvs",
    "temp",
    "wifi",
    "ble",
    "sleep",
    "pwm",
    "gpio_intr",
    "uart",
    "adc",
    "spi"
  ],
  "notes": "Rule D convenience binary: 10 sub-tests in one firmware. 4 jumpers required. GPIO4-5, GPIO6-7, GPIO8-1, GPIO10-3. GPIO8 used for ADC drive (GPIO2/LP-IO cannot output HIGH with ADC1 active on ESP32-C3).",
  "wiring": {
    "required": [
      {
        "from": "GPIO4",
        "to": "GPIO5",
        "label": "GPIO intr drive <-> input"
      },
      {
        "from": "GPIO6",
        "to": "GPIO7",
        "label": "UART1 TX -> RX loopback"
      },
      {
        "from": "GPIO8",
        "to": "GPIO1",
        "label": "ADC drive -> ADC1_CH1 (GPIO8, not GPIO2)"
      },
      {
        "from": "GPIO10",
        "to": "GPIO3",
        "label": "SPI2 MOSI <-> MISO loopback"
      }
    ]
  },
  "build": {
    "project_dir": "firmware/targets/esp32c3_devkit/test_full_suite",
    "artifact_stem": "ael_esp32c3_devkit_test_full_suite",
    "build_dir": "artifacts/build_esp32c3_devkit_test_full_suite"
  },
  "preflight": {
    "enabled": false
  },
  "observe_uart": {
    "enabled": true,
    "port": "/dev/ttyACM1",
    "baud": 115200,
    "profile": "espidf",
    "duration_s": 60,
    "reset_strategy": "none",
    "boot_signatures": [
      "rst:0x"
    ],
    "expect_patterns": [
      "AEL_NVS.*PASS",
      "AEL_TEMP.*PASS",
      "AEL_WIFI.*PASS",
      "AEL_BLE.*PASS",
      "AEL_SLEEP.*PASS",
      "AEL_PWM.*PASS",
      "AEL_INTR.*PASS",
      "AEL_UART.*PASS",
      "AEL_ADC.*PASS",
      "AEL_SPI.*PASS",
      "AEL_SUITE_FULL DONE passed=10 failed=0"
    ]
  }
}
