{
  "schema_version": "1.0",
  "name": "esp32c3_devkit_test_adc",
  "test_kind": "instrument_specific",
  "board": "esp32c3_devkit_native_usb",
  "supported_instruments": [],
  "requires": {
    "mailbox": false,
    "datacapture": false
  },
  "labels": [
    "stage2",
    "selftest",
    "truth_layer"
  ],
  "covers": [
    "adc"
  ],
  "notes": "Stage 2: ADC1 loopback. GPIO8 drives -> GPIO1 (ADC1_CH1). GPIO8 used instead of GPIO2: ESP32-C3 LP-IO (GPIO0-GPIO4) output HIGH is suppressed once ADC1 unit is active.",
  "wiring": {
    "required": [
      {
        "from": "GPIO8",
        "to": "GPIO1",
        "label": "ADC drive -> ADC1_CH1 input"
      }
    ]
  },
  "build": {
    "project_dir": "firmware/targets/esp32c3_devkit/test_adc",
    "artifact_stem": "ael_esp32c3_devkit_test_adc",
    "build_dir": "artifacts/build_esp32c3_devkit_test_adc"
  },
  "preflight": {
    "enabled": false
  },
  "observe_uart": {
    "enabled": true,
    "port": "/dev/ttyACM1",
    "baud": 115200,
    "profile": "espidf",
    "duration_s": 8,
    "reset_strategy": "none",
    "boot_signatures": [
      "rst:0x"
    ],
    "expect_patterns": [
      "AEL_ADC.*PASS"
    ]
  }
}
