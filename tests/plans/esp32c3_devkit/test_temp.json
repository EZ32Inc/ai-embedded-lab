{
  "schema_version": "1.0",
  "name": "esp32c3_devkit_test_temp",
  "test_kind": "instrument_specific",
  "board": "esp32c3_devkit_native_usb",
  "supported_instruments": [],
  "requires": {
    "mailbox": false,
    "datacapture": false
  },
  "labels": [
    "stage1",
    "selftest",
    "truth_layer"
  ],
  "covers": [
    "temp"
  ],
  "notes": "Stage 1: internal temperature sensor. No wiring required.",
  "wiring": {
    "required": []
  },
  "build": {
    "project_dir": "firmware/targets/esp32c3_devkit/test_temp",
    "artifact_stem": "ael_esp32c3_devkit_test_temp",
    "build_dir": "artifacts/build_esp32c3_devkit_test_temp"
  },
  "preflight": {
    "enabled": false
  },
  "observe_uart": {
    "enabled": true,
    "port": "/dev/ttyACM1",
    "baud": 115200,
    "profile": "espidf",
    "duration_s": 6,
    "reset_strategy": "none",
    "boot_signatures": [
      "rst:0x"
    ],
    "expect_patterns": [
      "AEL_TEMP.*PASS"
    ]
  }
}
