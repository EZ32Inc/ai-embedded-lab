{
  "schema_version": "1.0",
  "test_kind": "baremetal_mailbox",
  "name": "stm32f411ceu6_uart_multibyte",
  "board": "stm32f411ceu6",
  "supported_instruments": ["esp32jtag"],
  "requires": { "mailbox": true, "datacapture": false },
  "labels": ["mailbox", "portable", "selfcheck"],
  "covers": ["usart1", "uart_loopback"],
  "build": {
    "project_dir": "firmware/targets/stm32f411ceu6_uart_multibyte",
    "artifact_stem": "stm32f411_uart_multibyte_app",
    "build_dir": "artifacts/build_stm32f411ceu6_uart_multibyte"
  },
  "signal_checks": [],
  "mailbox_verify": { "settle_s": 5.0, "addr": "0x2000FC00" },
  "bench_setup": {
    "notes": "UART multi-byte loopback test. PA9 (USART1_TX AF7) → PA10 (USART1_RX AF7), 115200 8N1. Sends {0x55, 0xAA, 0x12, 0x34} one at a time and verifies each echoed byte. On FAIL: error_code bits 0-3 = per-byte failure mask. detail0 = matched byte count (0–3). On PASS: detail0 = heartbeat counter.",
    "peripheral_signals": [
      {
        "role": "UART_TX",
        "dut_signal": "PA9",
        "direction": "output",
        "status": "provisioned",
        "notes": "USART1_TX AF7. Wire: PA9 → PA10 (loopback)."
      },
      {
        "role": "UART_RX",
        "dut_signal": "PA10",
        "direction": "input",
        "status": "provisioned",
        "notes": "USART1_RX AF7. Wire: PA9 → PA10 (loopback)."
      }
    ]
  }
}
