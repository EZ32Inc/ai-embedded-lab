{
  "name": "stm32f401_gpio_loopback_banner",
  "board": "stm32f401rct6",
  "pin": "sig",
  "duration_s": 1.0,
  "min_freq_hz": 15.0,
  "max_freq_hz": 35.0,
  "duty_min": 0.4,
  "duty_max": 0.6,
  "min_edges": 2,
  "max_edges": 20000,
  "build": {
    "project_dir": "firmware/targets/stm32f401_gpio_loopback",
    "artifact_stem": "stm32f401_gpio_loopback_app",
    "build_dir": "artifacts/build_stm32f401_gpio_loopback_banner"
  },
  "bench_setup": {
    "peripheral_signals": [
      { "role": "GPIO_LOOPBACK_SOURCE", "dut_signal": "PA8", "direction": "output", "notes": "Firmware toggles PA8." },
      { "role": "GPIO_LOOPBACK_INPUT",  "dut_signal": "PA6", "direction": "input",  "notes": "Firmware samples PA6 via PA8→PA6 loopback." }
    ],
    "external_inputs": [
      {
        "source": "GPIO_LOOPBACK",
        "dut_signal": "PA6",
        "kind": "digital_loopback",
        "required": true,
        "status": "manual_loopback_required",
        "notes": "Physically connect PA8 to PA6. Firmware exports loopback-valid status on PA2."
      }
    ]
  }
}
