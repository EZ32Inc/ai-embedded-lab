{
  "schema_version": "1.0",
  "name": "test_nvs",
  "test_kind": "instrument_specific",
  "board": "esp32c5_devkit_dual_usb",
  "supported_instruments": ["esp32_meter"],
  "requires": {"mailbox": false, "datacapture": false},
  "labels": ["stage1"],
  "covers": ["nvs", "flash"],
  "notes": "Stage 1: NVS read/write verification. No jumpers required.",
  "wiring": {"required": []},
  "build": {
    "project_dir": "firmware/targets/esp32c5_devkit/test_nvs",
    "artifact_stem": "test_nvs",
    "build_dir": "artifacts/build_esp32c5_devkit_test_nvs"
  },
  "preflight": {"enabled": false},
  "observe_uart": {
    "enabled": true,
    "instrument_spec": "esp32c5_uart_bridge",
    "port": "/dev/ttyACM0",
    "baud": 115200,
    "profile": "espidf",
    "boot_signatures": ["rst:0x"],
    "reset_strategy": "rts",
    "duration_s": 20,
    "expect_patterns": ["AEL_NVS.*PASS"]
  }
}
