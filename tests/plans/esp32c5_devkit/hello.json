{
  "schema_version": "1.0",
  "name": "hello",
  "test_kind": "instrument_specific",
  "board": "esp32c5_devkit_dual_usb",
  "supported_instruments": ["esp32_meter"],
  "requires": {"mailbox": false, "datacapture": false},
  "labels": ["stage0", "smoke"],
  "covers": ["boot", "uart"],
  "notes": "Stage 0 bare-board smoke test. No jumpers. Verifies USB CDC enumeration, IDF boot, printf on CH341 UART bridge.",
  "wiring": {"required": []},
  "build": {
    "project_dir": "firmware/targets/esp32c5_devkit/hello",
    "artifact_stem": "hello",
    "build_dir": "artifacts/build_esp32c5_devkit_hello"
  },
  "preflight": {"enabled": false},
  "observe_uart": {
    "enabled": true,
    "instrument_spec": "esp32c5_uart_bridge",
    "port": "/dev/ttyACM0",
    "baud": 115200,
    "profile": "espidf",
    "boot_signatures": ["rst:0x"],
    "reset_strategy": "rts",
    "duration_s": 20,
    "expect_patterns": ["AEL_HELLO board=ESP32C5 PASS"]
  }
}
