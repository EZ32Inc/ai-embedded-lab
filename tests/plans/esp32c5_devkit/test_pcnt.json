{
  "schema_version": "1.0",
  "name": "test_pcnt",
  "test_kind": "instrument_specific",
  "board": "esp32c5_devkit_dual_usb",
  "supported_instruments": ["esp32_meter"],
  "requires": {"mailbox": false, "datacapture": false},
  "labels": ["stage2"],
  "covers": ["pcnt", "gpio"],
  "notes": "Stage 2: GPIO2 drives 100 pulses, GPIO3 PCNT counts = 100. Jumper: GPIO2 ↔ GPIO3.",
  "wiring": {
    "required": [
      {"from": "GPIO2", "to": "GPIO3", "label": "Wire 1 — PCNT pulse out / count in (shared with GPIO intr)"}
    ]
  },
  "build": {
    "project_dir": "firmware/targets/esp32c5_devkit/test_pcnt",
    "artifact_stem": "test_pcnt",
    "build_dir": "artifacts/build_esp32c5_devkit_test_pcnt"
  },
  "preflight": {"enabled": false},
  "observe_uart": {
    "enabled": true,
    "instrument_spec": "esp32c5_uart_bridge",
    "port": "/dev/ttyACM0",
    "baud": 115200,
    "profile": "espidf",
    "boot_signatures": ["rst:0x"],
    "reset_strategy": "rts",
    "duration_s": 20,
    "expect_patterns": ["AEL_PCNT.*PASS"]
  }
}
