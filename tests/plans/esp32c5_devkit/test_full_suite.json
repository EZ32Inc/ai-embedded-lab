{
  "schema_version": "1.0",
  "name": "test_full_suite",
  "test_kind": "instrument_specific",
  "board": "esp32c5_devkit_dual_usb",
  "supported_instruments": ["esp32_meter"],
  "requires": {"mailbox": false, "datacapture": false},
  "labels": ["rule_d", "full_suite"],
  "covers": ["gpio", "nvs", "temperature", "wifi", "ble", "sleep", "pwm", "pcnt", "uart", "adc", "spi", "i2c"],
  "notes": "Rule D convenience layer: all 13 sub-tests in one firmware. 6 jumpers required: GPIO2<->GPIO3, GPIO4<->GPIO5, GPIO6->GPIO1, GPIO7<->GPIO9, GPIO8<->GPIO14, GPIO13<->GPIO23.",
  "wiring": {
    "required": [
      {"from": "GPIO2",  "to": "GPIO3",  "label": "Wire 1 — GPIO interrupt drive / PCNT input (shared)"},
      {"from": "GPIO4",  "to": "GPIO5",  "label": "Wire 2 — UART1 TX -> RX loopback"},
      {"from": "GPIO6",  "to": "GPIO1",  "label": "Wire 3 — ADC drive -> ADC1_CH0 (GPIO6=LP-IO safe)"},
      {"from": "GPIO7",  "to": "GPIO9",  "label": "Wire 4 — SPI2 MOSI <-> MISO loopback"},
      {"from": "GPIO8",  "to": "GPIO14", "label": "Wire 5 — I2C SDA: bit-bang master <-> HW V2 slave"},
      {"from": "GPIO13", "to": "GPIO23", "label": "Wire 6 — I2C SCL: bit-bang master <-> HW V2 slave"}
    ]
  },
  "build": {
    "project_dir": "firmware/targets/esp32c5_devkit/test_full_suite",
    "artifact_stem": "test_full_suite",
    "build_dir": "artifacts/build_esp32c5_devkit_test_full_suite"
  },
  "preflight": {"enabled": false},
  "observe_uart": {
    "enabled": true,
    "instrument_spec": "esp32c5_uart_bridge",
    "port": "/dev/ttyACM0",
    "baud": 115200,
    "profile": "espidf",
    "boot_signatures": ["rst:0x"],
    "reset_strategy": "rts",
    "duration_s": 60,
    "expect_patterns": [
      "AEL_HELLO board=ESP32C5 PASS",
      "AEL_TEMP.*PASS",
      "AEL_NVS.*PASS",
      "AEL_WIFI.*PASS",
      "AEL_BLE.*PASS",
      "AEL_SLEEP.*PASS",
      "AEL_PWM.*PASS",
      "AEL_INTR.*PASS",
      "AEL_PCNT.*PASS",
      "AEL_UART.*PASS",
      "AEL_ADC.*PASS",
      "AEL_SPI.*PASS",
      "AEL_I2C.*PASS",
      "AEL_SUITE_FULL DONE passed=13 failed=0"
    ]
  }
}
