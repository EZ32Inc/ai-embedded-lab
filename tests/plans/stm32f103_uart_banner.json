{
  "name": "stm32f103_uart_banner",
  "board": "stm32f103",
  "pin": "sig",
  "duration_s": 1.0,
  "expected_hz": 2.5,
  "min_edges": 2,
  "max_edges": 20000,
  "build": {
    "project_dir": "firmware/targets/stm32f103_uart",
    "artifact_stem": "stm32f103_uart_app",
    "build_dir": "artifacts/build_stm32f103_uart_banner"
  },
  "observe_uart": {
    "enabled": true,
    "port": "/dev/ttyUSB0",
    "baud": 115200,
    "profile": "stm32",
    "duration_s": 6,
    "expect_patterns": [
      "AEL_READY STM32F103 UART"
    ]
  },
  "bench_setup": {
    "instrument_roles": [
      {
        "role": "control_instrument",
        "instrument_id": "esp32jtag_stm32_uart",
        "endpoint": "192.168.2.99:4242",
        "required": true,
        "notes": "Used for flash/load and existing GPIO-side verification support."
      },
      {
        "role": "uart_instrument",
        "instrument_id": "usb_uart_bridge_daemon",
        "endpoint": "192.168.2.78:8767",
        "required": true,
        "notes": "Phase 2b remote bridge endpoint."
      }
    ],
    "serial_console": {
      "port": "/dev/ttyUSB0",
      "baud": 115200,
      "required": true
    },
    "peripheral_signals": [
      {
        "role": "uart_tx",
        "dut_signal": "PA9/USART1_TX",
        "direction": "output",
        "notes": "Connect STM32 PA9 to USB-UART RX."
      },
      {
        "role": "uart_rx",
        "dut_signal": "PA10/USART1_RX",
        "direction": "input",
        "notes": "Optional for Phase 1; connect USB-UART TX to STM32 PA10 only if bidirectional UART is needed."
      }
    ]
  }
}
