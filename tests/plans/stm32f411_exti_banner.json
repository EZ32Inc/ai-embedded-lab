{
  "name": "stm32f411_exti_banner",
  "board": "stm32f411ceu6",
  "pin": "sig",
  "duration_s": 1.0,
  "min_freq_hz": 15.0,
  "max_freq_hz": 35.0,
  "duty_min": 0.4,
  "duty_max": 0.6,
  "min_edges": 2,
  "max_edges": 20000,
  "build": {
    "project_dir": "firmware/targets/stm32f411_exti",
    "artifact_stem": "stm32f411_exti_app",
    "build_dir": "artifacts/build_stm32f411_exti_banner"
  },
  "bench_setup": {
    "peripheral_signals": [
      {
        "role": "EXTI_SOURCE",
        "dut_signal": "PA8",
        "direction": "output",
        "notes": "Firmware generates repeated edges on PA8."
      },
      {
        "role": "EXTI_SELF_CHECK_INPUT",
        "dut_signal": "PA6",
        "direction": "input",
        "notes": "Firmware counts EXTI events on PA6 through a manual PA8 -> PA6 loopback and encodes the result onto PA2."
      }
    ],
    "external_inputs": [
      {
        "source": "EXTI_LOOPBACK",
        "dut_signal": "PA6",
        "kind": "digital_loopback",
        "required": true,
        "status": "provisioned",
        "notes": "Execution contract: physically connect PA8 to PA6 so the DUT can confirm EXTI edge detection internally. AEL should observe PA2, not PA8/PA6, for the bounded proof."
      }
    ]
  }
}
