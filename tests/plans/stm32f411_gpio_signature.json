{
  "name": "stm32f411_gpio_signature",
  "board": "stm32f411ceu6",
  "build": {
    "project_dir": "firmware/targets/stm32f411ceu6",
    "artifact_stem": "stm32f411_app",
    "build_dir": "artifacts/build_stm32f411_gpio_signature"
  },
  "signal_checks": [
    {
      "name": "pa2_fast",
      "pin": "pa2",
      "duration_s": 1.0,
      "min_freq_hz": 1000.0,
      "max_freq_hz": 500000.0,
      "duty_min": 0.35,
      "duty_max": 0.65,
      "min_edges": 100,
      "max_edges": 60000
    },
    {
      "name": "pa3_half_rate",
      "pin": "pa3",
      "duration_s": 1.0,
      "min_freq_hz": 500.0,
      "max_freq_hz": 250000.0,
      "duty_min": 0.35,
      "duty_max": 0.65,
      "min_edges": 50,
      "max_edges": 60000
    }
  ],
  "signal_relations": [
    {
      "type": "frequency_ratio",
      "numerator": "pa2_fast",
      "denominator": "pa3_half_rate",
      "min_ratio": 1.8,
      "max_ratio": 2.2
    }
  ],
  "bench_setup": {
    "peripheral_signals": [
      {
        "role": "GPIO_SIGNATURE_FAST",
        "dut_signal": "PA2",
        "direction": "output",
        "notes": "Firmware drives PA2 as the primary fast square-wave output for direct capture."
      },
      {
        "role": "GPIO_SIGNATURE_HALF_RATE",
        "dut_signal": "PA3",
        "direction": "output",
        "notes": "Firmware drives PA3 at half the PA2 rate so the control instrument can verify the ratio directly."
      },
      {
        "role": "STATUS_LED",
        "dut_signal": "PC13",
        "direction": "output",
        "notes": "Operator-visible heartbeat during the first STM32F411 bring-up round."
      }
    ]
  }
}
