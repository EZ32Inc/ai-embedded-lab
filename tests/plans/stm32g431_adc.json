  "duration_s": 1.0,
  "min_freq_hz": 30.0,
  "max_freq_hz": 70.0,
  "duty_min": 0.3,
  "duty_max": 0.7,
  "min_edges": 5,
  "max_edges": 20000,
  "build": {
    "project_dir": "firmware/targets/stm32g431_adc",
    "artifact_stem": "stm32g431_adc_app",
