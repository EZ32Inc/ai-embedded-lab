{
  "schema_version": "1.0",
  "name": "esp32c5_dual_uart_probe_via_bridge",
  "test_kind": "instrument_specific",
  "board": "esp32c5_devkit_dual_usb",
  "supported_instruments": ["esp32_meter"],
  "requires": {"mailbox": false, "datacapture": false},
  "labels": ["uart", "selftest_only"],
  "covers": ["uart"],
  "notes": "Validates UART0 via CH341 bridge path (/dev/ttyACM0, GPIO11 TX). Expects AEL_UART0 pattern which appears ONLY on this port — not on USB JTAG port. Proves role, not just connectivity.",
  "build": {
    "project_dir": "firmware/targets/esp32c5_dual_uart_probe",
    "artifact_stem": "ael_esp32c5_dual_uart_probe",
    "build_dir": "artifacts/build_esp32c5_dual_uart_probe"
  },
  "preflight": {
    "enabled": false
  },
  "observe_uart": {
    "enabled": true,
    "instrument_spec": "esp32c5_uart_bridge",
    "port": "/dev/ttyACM0",
    "baud": 115200,
    "profile": "espidf",
    "duration_s": 10,
    "expect_patterns": [
      "AEL_UART0 ESP32C5"
    ]
  }
}
