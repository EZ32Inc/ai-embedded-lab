{
  "schema_version": "1.0",
  "name": "esp32c6_devkit_test_ble",
  "test_kind": "instrument_specific",
  "board": "esp32c6_devkit_dual_usb",
  "supported_instruments": [],
  "requires": {
    "mailbox": false,
    "datacapture": false
  },
  "labels": [
    "stage1",
    "selftest",
    "truth_layer"
  ],
  "covers": [
    "ble"
  ],
  "notes": "Stage 1: BLE passive scan (NimBLE). No wiring required.",
  "wiring": {
    "required": []
  },
  "build": {
    "project_dir": "firmware/targets/esp32c6_devkit/test_ble",
    "artifact_stem": "ael_esp32c6_devkit_test_ble",
    "build_dir": "artifacts/build_esp32c6_devkit_test_ble"
  },
  "preflight": {
    "enabled": false
  },
  "observe_uart": {
    "enabled": true,
    "port": "/dev/ttyACM1",
    "baud": 115200,
    "profile": "espidf",
    "duration_s": 12,
    "reset_strategy": "rts",
    "expect_patterns": [
      "AEL_BLE.*PASS"
    ],
    "boot_signatures": [
      "rst:0x"
    ]
  }
