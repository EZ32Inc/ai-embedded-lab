{
  "schema_version": "1.0",
  "name": "esp32c6_devkit_test_i2c",
  "test_kind": "instrument_specific",
  "board": "esp32c6_devkit_dual_usb",
  "supported_instruments": [],
  "requires": {
    "mailbox": false,
    "datacapture": false
  },
  "labels": [
    "stage2",
    "selftest",
    "truth_layer"
  ],
  "covers": [
    "i2c"
  ],
  "notes": "Stage 2: I2C loopback. V2 slave (I2C0 GPIO8/GPIO9) + bit-bang master (GPIO6/GPIO7). Two jumpers required.",
  "wiring": {
    "required": [
      {
        "from": "GPIO8",
        "to": "GPIO6",
        "label": "I2C SDA: slave (I2C0) <-> bit-bang master"
      },
      {
        "from": "GPIO9",
        "to": "GPIO7",
        "label": "I2C SCL: slave (I2C0) <-> bit-bang master"
      }
    ]
  },
  "build": {
    "project_dir": "firmware/targets/esp32c6_devkit/test_i2c",
    "artifact_stem": "ael_esp32c6_devkit_test_i2c",
    "build_dir": "artifacts/build_esp32c6_devkit_test_i2c"
  },
  "preflight": {
    "enabled": false
  },
  "observe_uart": {
    "enabled": true,
    "port": "/dev/ttyACM1",
    "baud": 115200,
    "profile": "espidf",
    "duration_s": 12,
    "reset_strategy": "rts",
    "expect_patterns": [
      "AEL_I2C.*PASS"
    ],
    "boot_signatures": [
      "rst:0x"
    ]
  }
}