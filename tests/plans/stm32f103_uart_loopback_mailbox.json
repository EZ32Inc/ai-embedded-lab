{
  "name": "stm32f103_uart_loopback_mailbox",
  "board": "stm32f103_gpio",
  "preflight": { "enabled": false },
  "build": {
    "project_dir": "firmware/targets/stm32f103_uart_loopback_mailbox",
    "artifact_stem": "stm32f103_uart_loopback_mailbox_app",
    "build_dir": "artifacts/build_stm32f103_uart_loopback_mailbox"
  },
  "signal_checks": [],
  "mailbox_verify": {
    "addr": "0x20004C00",
    "settle_s": 1.0
  },
  "bench_setup": {
    "notes": "UART1 loopback mailbox test. Requires PA9/USART1_TX -> PA10/USART1_RX. DUT performs bounded UART self-check and reports PASS/FAIL through the AEL mailbox.",
    "peripheral_signals": [
      {
        "role": "USART1_TX",
        "dut_signal": "PA9",
        "direction": "output"
      },
      {
        "role": "USART1_RX",
        "dut_signal": "PA10",
        "direction": "input"
      }
    ]
  }
}
