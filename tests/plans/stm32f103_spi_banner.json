{
  "name": "stm32f103_spi_banner",
  "board": "stm32f103",
  "pin": "sig",
  "duration_s": 1.0,
  "expected_hz": 2.5,
  "min_edges": 2,
  "max_edges": 20000,
  "build": {
    "project_dir": "firmware/targets/stm32f103_spi",
    "artifact_stem": "stm32f103_spi_app",
    "build_dir": "artifacts/build_stm32f103_spi_banner"
  },
  "observe_uart": {
    "enabled": true,
    "port": "/dev/ttyUSB0",
    "baud": 115200,
    "profile": "stm32",
    "duration_s": 6,
    "expect_patterns": [
      "AEL_READY STM32F103 SPI"
    ]
  },
  "bench_setup": {
    "serial_console": {
      "port": "/dev/ttyUSB0",
      "baud": 115200,
      "required": true
    },
    "peripheral_signals": [
      {
        "role": "SPI1_SCK",
        "dut_signal": "PA5",
        "direction": "output"
      },
      {
        "role": "SPI1_MISO",
        "dut_signal": "PA6",
        "direction": "input"
      },
      {
        "role": "SPI1_MOSI",
        "dut_signal": "PA7",
        "direction": "output"
      }
    ]
  }
}
