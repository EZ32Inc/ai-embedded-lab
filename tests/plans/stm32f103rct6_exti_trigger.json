{
  "name": "stm32f103rct6_exti_trigger",
  "board": "stm32f103rct6",
  "preflight": { "enabled": false },
  "build": {
    "project_dir": "firmware/targets/stm32f103rct6_exti_trigger",
    "artifact_stem": "stm32f103rct6_exti_trigger_app",
    "build_dir": "artifacts/build_stm32f103rct6_exti_trigger"
  },
  "signal_checks": [],
  "mailbox_verify": {
    "settle_s": 4.0,
    "addr": "0x2000BC00",
    "skip_attach": true
  },
  "bench_setup": {
    "notes": "EXTI trigger: PB8 (output) drives 10 rising edges, PB9 -> EXTI9_5 IRQ23. PASS after 10 interrupts. detail0 = interrupt count. AFIO_EXTICR3[7:4]=0x1 routes PB9 to EXTI9.",
    "peripheral_signals": [
      {
        "role": "EXTI_DRIVER",
        "dut_signal": "PB8",
        "direction": "output",
        "notes": "GPIO output push-pull. Wire: PB8 -> PB9."
      },
      {
        "role": "EXTI_INPUT",
        "dut_signal": "PB9",
        "direction": "input",
        "notes": "EXTI9, input floating. Wire: PB8 -> PB9."
      }
    ]
  }
}
