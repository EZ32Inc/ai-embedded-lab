{
  "name": "rp2040_adc_banner",
  "board": "rp2040_pico",
  "pin": "sig",
  "sample_rate_hz": 260000,
  "duration_s": 1.0,
  "min_edges": 2,
  "max_edges": 20000,
  "build": {
    "project_dir": "firmware/targets/rp2040_pico_adc",
    "artifact_stem": "pico_adc_banner",
    "build_dir": "artifacts/build_rp2040_adc_banner"
  },
  "observe_uart": {
    "enabled": true,
    "port": "/dev/ttyACM0",
    "baud": 115200,
    "profile": "rp2040",
    "duration_s": 6,
    "expect_patterns": [
      "AEL_READY RP2040 ADC"
    ]
  },
  "bench_setup": {
    "serial_console": {
      "port": "/dev/ttyACM0",
      "baud": 115200,
      "required": true
    },
    "peripheral_signals": [
      {
        "role": "ADC0",
        "dut_signal": "GPIO26/ADC0",
        "direction": "input"
      }
    ],
    "external_inputs": [
      {
        "source": "UNSPECIFIED_ANALOG_SOURCE",
        "dut_signal": "GPIO26/ADC0",
        "kind": "analog_in",
        "required": false,
        "status": "not_defined",
        "notes": "Current example reports local ADC samples but does not define an external analog stimulus contract."
      }
    ]
  }
}
