{
  "schema_version": "1.0",
  "name": "esp32_wroom32d_test_i2c",
  "test_kind": "instrument_specific",
  "board": "esp32_wroom32d_cp210x",
  "supported_instruments": [],
  "requires": {
    "mailbox": false,
    "datacapture": false
  },
  "labels": [
    "stage2",
    "selftest",
    "truth_layer"
  ],
  "covers": [
    "i2c"
  ],
  "notes": "Stage 2: I2C master+slave loopback. Two jumpers required. Master I2C0 on GPIO21/22; slave I2C1 on GPIO13/14. Separate pin pairs required \u2014 ESP32 GPIO matrix cannot assign two I2C controllers to the same GPIO pair. Uses V1 slave driver (V2 requires SCL-stretch HW not present on ESP32 classic).",
  "wiring": {
    "required": [
      {
        "from": "GPIO21",
        "to": "GPIO13",
        "label": "I2C SDA: master (I2C0) \u2194 slave (I2C1)"
      },
      {
        "from": "GPIO22",
        "to": "GPIO14",
        "label": "I2C SCL: master (I2C0) \u2194 slave (I2C1)"
      }
    ]
  },
  "build": {
    "project_dir": "firmware/targets/esp32_wroom32d/test_i2c",
    "artifact_stem": "ael_esp32_wroom32d_test_i2c",
    "build_dir": "artifacts/build_esp32_wroom32d_test_i2c"
  },
  "preflight": {
    "enabled": false
  },
  "observe_uart": {
    "enabled": true,
    "port": "/dev/ttyUSB0",
    "baud": 115200,
    "profile": "espidf",
    "duration_s": 10,
    "reset_strategy": "rts",
    "expect_patterns": [
      "AEL_I2C.*PASS"
    ]
  }
}