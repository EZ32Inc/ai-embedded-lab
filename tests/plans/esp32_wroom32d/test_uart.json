{
  "schema_version": "1.0",
  "name": "esp32_wroom32d_test_uart",
  "test_kind": "instrument_specific",
  "board": "esp32_wroom32d_cp210x",
  "supported_instruments": [],
  "requires": {"mailbox": false, "datacapture": false},
  "labels": ["stage2", "selftest"],
  "covers": ["uart"],
  "notes": "Stage 2: UART1 TX→RX loopback. GPIO17↔GPIO16 jumper required. Console is UART0 (GPIO1/3 via CP210X); UART1 is the test port — no conflict.",
  "wiring": {
    "required": [
      {"from": "GPIO17", "to": "GPIO16", "label": "UART1 TX → RX loopback"}
    ]
  },
  "build": {
    "project_dir": "firmware/targets/esp32_wroom32d/test_uart",
    "artifact_stem": "ael_esp32_wroom32d_test_uart",
    "build_dir": "artifacts/build_esp32_wroom32d_test_uart"
  },
  "preflight": {"enabled": false},
  "observe_uart": {
    "enabled": true,
    "port": "/dev/ttyUSB0",
    "baud": 115200,
    "profile": "espidf",
    "duration_s": 8,
    "reset_strategy": "rts",
    "expect_patterns": ["AEL_UART.*PASS"]
  }
}
