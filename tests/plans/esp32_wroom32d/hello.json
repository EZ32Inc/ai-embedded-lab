{
  "schema_version": "1.0",
  "name": "esp32_wroom32d_hello",
  "test_kind": "instrument_specific",
  "board": "esp32_wroom32d_cp210x",
  "supported_instruments": [],
  "requires": {
    "mailbox": false,
    "datacapture": false
  },
  "labels": [
    "stage0",
    "bringup",
    "truth_layer"
  ],
  "covers": [
    "console"
  ],
  "notes": "Stage 0 bare-board validation. No jumpers. Verifies flash, boot, and UART0 console via CP210X. Must PASS before any wired test is attempted.",
  "wiring": {
    "required": []
  },
  "build": {
    "project_dir": "firmware/targets/esp32_wroom32d/hello",
    "artifact_stem": "ael_esp32_wroom32d_hello",
    "build_dir": "artifacts/build_esp32_wroom32d_hello"
  },
  "preflight": {
    "enabled": false
  },
  "observe_uart": {
    "enabled": true,
    "port": "/dev/ttyUSB0",
    "baud": 115200,
    "profile": "espidf",
    "duration_s": 20,
    "reset_strategy": "rts",
    "expect_patterns": [
      "AEL_HELLO_DONE"
    ]
  }
}