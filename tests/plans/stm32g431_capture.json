  "pin": "sig",
  "duration_s": 1.0,
  "min_freq_hz": 30.0,
  "max_freq_hz": 70.0,
  "duty_min": 0.3,
  "duty_max": 0.7,
  "min_edges": 5,
  "max_edges": 20000,
  "build": {
    "project_dir": "firmware/targets/stm32g431_capture",
    "artifact_stem": "stm32g431_capture_app",
    "build_dir": "artifacts/build_stm32g431_capture"
  },
  "bench_setup": {
    "peripheral_signals": [
      { "role": "TIM1_PWM_OUT", "dut_signal": "PA8", "direction": "output",
        "notes": "TIM1_CH1 AF6, 50Hz 50% duty PWM. PA8→PA6 loopback wire." },
      { "role": "TIM3_CAPTURE",  "dut_signal": "PA6", "direction": "input",
        "notes": "TIM3_CH1 AF2 input capture. PA2 toggles ~50Hz when capture period is 200±50 ticks." }
    ]
  }
