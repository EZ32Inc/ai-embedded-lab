{
  "name": "stm32g431_gpio_signature",
  "board": "stm32g431cbu6",
  "required_capabilities": ["flash_program", "logic_capture", "reset_control"],
  "applies_to": ["board", "bare_mcu"],
  "requires_dut_features": ["programmable_via_swd", "has_gpio"],
  "build": {
    "project_dir": "firmware/targets/stm32g431cbu6",
    "artifact_stem": "stm32g431_app",
    "build_dir": "artifacts/build_stm32g431_gpio_signature"
  },
  "signal_checks": [
    {
      "name": "pa2_fast",
      "pin": "pa2",
      "duration_s": 1.0,
      "min_freq_hz": 150.0,
      "max_freq_hz": 400.0,
      "duty_min": 0.35,
      "duty_max": 0.65,
      "min_edges": 50,
      "max_edges": 2000
    },
    {
      "name": "pa3_half_rate",
      "pin": "pa3",
      "duration_s": 1.0,
      "min_freq_hz": 75.0,
      "max_freq_hz": 200.0,
      "duty_min": 0.35,
      "duty_max": 0.65,
      "min_edges": 25,
      "max_edges": 1000
    }
  ],
  "signal_relations": [
    {
      "type": "frequency_ratio",
      "numerator": "pa2_fast",
      "denominator": "pa3_half_rate",
      "min_ratio": 1.8,
      "max_ratio": 2.2
    }
  ],
  "bench_setup": {
    "peripheral_signals": [
      {
        "role": "GPIO_SIGNATURE_FAST",
        "dut_signal": "PA2",
        "direction": "output",
        "notes": "Firmware drives PA2 at ~250 Hz as the primary signature output. SysTick-timed, 1kHz from 16MHz HSI."
      },
      {
        "role": "GPIO_SIGNATURE_HALF_RATE",
        "dut_signal": "PA3",
        "direction": "output",
        "notes": "Firmware drives PA3 at ~125 Hz (half of PA2) for ratio verification."
      },
      {
        "role": "STATUS_LED",
        "dut_signal": "PA8",
        "direction": "output",
        "notes": "Operator-visible heartbeat LED on PA8, active-high, 1Hz blink."
      }
    ]
  }
}
