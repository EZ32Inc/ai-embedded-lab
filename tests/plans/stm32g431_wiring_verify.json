{
  "schema_version": "1.0",
  "test_kind": "baremetal_mailbox",
  "name": "stm32g431_wiring_verify",
  "board": "stm32g431cbu6",
  "supported_instruments": ["esp32jtag"],
  "requires": {
    "mailbox": true,
    "datacapture": false
  },
  "labels": ["mailbox", "portable", "selfcheck"],
  "covers": ["gpio", "uart", "adc", "wiring"],
  "build": {
    "project_dir": "firmware/targets/stm32g431_wiring_verify",
    "artifact_stem": "stm32g431_wiring_verify_app",
    "build_dir": "artifacts/build_stm32g431_wiring_verify"
  },
  "signal_checks": [],
  "mailbox_verify": {
    "settle_s": 5.0,
    "addr": "0x20007F00"
  },
  "bench_setup": {
    "notes": "Stage 2 wiring verify. Firmware runs GPIO, UART, and ADC loopback tests internally. Pass/fail and per-wire error bitmask read from mailbox via SWD. On FAIL: error_code bitmask: bit0=GPIO_HIGH (PA8=H→PA6 read L), bit1=GPIO_LOW (PA8=L→PA6 read H), bit2=UART (PA9→PA10 mismatch/timeout), bit3=ADC_HIGH (PB1=H→PB0 ADC<3000), bit4=ADC_LOW (PB1=L→PB0 ADC>1000).",
    "peripheral_signals": [
      {
        "role": "GPIO_OUT",
        "dut_signal": "PA8",
        "direction": "output",
        "status": "provisioned",
        "notes": "GPIO loopback driver. Wire: PA8 ↔ PA6."
      },
      {
        "role": "GPIO_IN",
        "dut_signal": "PA6",
        "direction": "input",
        "status": "provisioned",
        "notes": "GPIO loopback receiver. Wire: PA8 ↔ PA6."
      },
      {
        "role": "USART1_TX",
        "dut_signal": "PA9",
        "direction": "output",
        "status": "provisioned",
        "notes": "USART1 TX AF7, 115200 8N1. Wire: PA9 ↔ PA10."
      },
      {
        "role": "USART1_RX",
        "dut_signal": "PA10",
        "direction": "input",
        "status": "provisioned",
        "notes": "USART1 RX AF7. Wire: PA9 ↔ PA10."
      },
      {
        "role": "ADC_DRIVE",
        "dut_signal": "PB1",
        "direction": "output",
        "status": "provisioned",
        "notes": "GPIO output drives ADC input via wire. Wire: PB1 ↔ PB0."
      },
      {
        "role": "ADC1_IN15",
        "dut_signal": "PB0",
        "direction": "input",
        "status": "provisioned",
        "notes": "ADC1 channel 15 analog input (PB0). Wire: PB1 ↔ PB0."
      }
    ]
  }
}
