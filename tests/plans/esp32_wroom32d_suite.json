{
  "schema_version": "1.0",
  "name": "esp32_wroom32d_suite",
  "test_kind": "instrument_specific",
  "board": "esp32_wroom32d_cp210x",
  "supported_instruments": [],
  "requires": {"mailbox": false, "datacapture": false},
  "labels": ["selftest"],
  "covers": ["nvs", "wifi", "ble", "sleep", "pwm", "i2c", "gpio", "pcnt", "uart", "adc", "spi"],
  "notes": "11-test hardware suite for ESP32-WROOM-32D with CP210X USB-UART bridge. No external instrument. 6 jumpers required. ESP32 classic GPIO matrix cannot assign two I2C controllers to the same GPIO pair, so I2C uses separate pins with jumpers. No TEMP (ESP32 classic lacks temperature_sensor driver). Console UART0 via CP210X /dev/ttyUSB0. reset_strategy=rts required (CP210X asserts DTR on port open → download mode). I2C uses V1 slave driver (V2 requires SCL-stretch HW not present on ESP32 classic).",
  "wiring": {
    "required": [
      {"from": "GPIO25", "to": "GPIO26", "label": "Wire 1 — GPIO interrupt drive + PCNT input"},
      {"from": "GPIO17", "to": "GPIO16", "label": "Wire 2 — UART1 TX → RX loopback"},
      {"from": "GPIO33", "to": "GPIO34", "label": "Wire 3 — ADC drive → ADC1_CH6 input"},
      {"from": "GPIO23", "to": "GPIO19", "label": "Wire 4 — SPI2 MOSI ↔ MISO loopback"},
      {"from": "GPIO21", "to": "GPIO13", "label": "Wire 5 — I2C SDA: master (I2C0) ↔ slave (I2C1)"},
      {"from": "GPIO22", "to": "GPIO14", "label": "Wire 6 — I2C SCL: master (I2C0) ↔ slave (I2C1)"}
    ]
  },
  "build": {
    "project_dir": "firmware/targets/esp32_wroom32d_suite",
    "artifact_stem": "ael_esp32_wroom32d_suite",
    "build_dir": "artifacts/build_esp32_wroom32d_suite"
  },
  "preflight": {
    "enabled": false
  },
  "observe_uart": {
    "enabled": true,
    "port": "/dev/ttyUSB0",
    "baud": 115200,
    "profile": "espidf",
    "duration_s": 70,
    "reset_strategy": "rts",
    "expect_patterns": [
      "AEL_NVS.*PASS",
      "AEL_WIFI.*PASS",
      "AEL_BLE.*PASS",
      "AEL_SLEEP.*PASS",
      "AEL_PWM.*PASS",
      "AEL_I2C.*PASS",
      "AEL_INTR.*PASS",
      "AEL_PCNT.*PASS",
      "AEL_UART.*PASS",
      "AEL_ADC.*PASS",
      "AEL_SPI.*PASS",
      "AEL_SUITE_ESP32 DONE passed=11 failed=0"
    ]
  }
}
